{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Cargo",
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "parcel-carbon",
          "color": "#081020",
          "name": "Parcel Carbon"
        },
        {
          "slug": "parcel-charcoal",
          "color": "#1A2B3C",
          "name": "Parcel Charcoal"
        },
        {
          "slug": "parcel-slate",
          "color": "#4A6070",
          "name": "Parcel Slate"
        },
        {
          "slug": "parcel-mist",
          "color": "#7A9098",
          "name": "Parcel Mist"
        },
        {
          "slug": "parcel-linen",
          "color": "#E0DDD8",
          "name": "Parcel Linen"
        },
        {
          "slug": "parcel-cream",
          "color": "#E8E4DF",
          "name": "Parcel Cream"
        },
        {
          "slug": "parcel-orange",
          "color": "#E8622A",
          "name": "Parcel Orange"
        },
        {
          "slug": "parcel-orange-tint",
          "color": "#F8EDE4",
          "name": "Parcel Orange Tint"
        },
        {
          "slug": "parcel-rule",
          "color": "#C8C4BE",
          "name": "Parcel Rule"
        },
        {
          "slug": "parcel-ink",
          "color": "#0D1B2A",
          "name": "Parcel Ink"
        },
        {
          "slug": "parcel-pearl",
          "color": "#D8D4D0",
          "name": "Parcel Pearl"
        },
        {
          "slug": "parcel-stone",
          "color": "#5A6870",
          "name": "Parcel Stone"
        }
      ]
    },
    "custom": {
      "colophon-light": "#E8E4DF",
      "colophon-dark": "#0D1B2A",
      "colophon-accent": "#E8622A"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--parcel-cream)",
      "text": "var(--wp--preset--color--parcel-ink)"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--parcel-carbon)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--parcel-orange)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--parcel-carbon)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--parcel-orange)",
          "text": "var(--wp--preset--color--parcel-cream)"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "color": {
          "text": "var(--wp--preset--color--parcel-carbon)"
        }
      },
      "core/navigation": {
        "color": {
          "text": "var(--wp--preset--color--parcel-ink)"
        }
      }
    }
  }
}

{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "960px",
			"wideSize": "1280px"
		},
		"color": {
			"link": true,
			"palette": [
				{
					"slug": "parcel-carbon",
					"color": "#1c1c1c",
					"name": "Parcel Carbon"
				},
				{
					"slug": "parcel-charcoal",
					"color": "#2e2e2e",
					"name": "Parcel Charcoal"
				},
				{
					"slug": "parcel-slate",
					"color": "#666666",
					"name": "Parcel Slate"
				},
				{
					"slug": "parcel-mist",
					"color": "#a0a0a0",
					"name": "Parcel Mist"
				},
				{
					"slug": "parcel-linen",
					"color": "#f5f2ee",
					"name": "Parcel Linen"
				},
				{
					"slug": "parcel-cream",
					"color": "#faf9f7",
					"name": "Parcel Cream"
				},
				{
					"slug": "parcel-orange",
					"color": "#e8622a",
					"name": "Parcel Orange"
				},
				{
					"slug": "parcel-orange-tint",
					"color": "#fdf0ea",
					"name": "Parcel Orange Tint"
				},
				{
					"slug": "parcel-rule",
					"color": "#e0dbd4",
					"name": "Parcel Rule"
				},
				{
					"slug": "parcel-ink",
					"color": "#1c1917",
					"name": "Parcel Ink"
				},
				{
					"slug": "parcel-pearl",
					"color": "#f2f0ed",
					"name": "Parcel Pearl"
				},
				{
					"slug": "parcel-stone",
					"color": "#78716c",
					"name": "Parcel Stone"
				}
			],
			"defaultPalette": false,
			"defaultGradients": false,
			"defaultDuotone": false
		},
		"typography": {
			"fontFamilies": [
				{
					"slug": "syne",
					"name": "Syne",
					"fontFamily": "'Syne', 'Futura', 'Trebuchet MS', sans-serif",
					"fontFace": [
						{
							"fontFamily": "Syne",
							"fontStyle": "normal",
							"fontWeight": "400 800",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/syne/syne-variable.woff2"
							]
						}
					]
				},
				{
					"slug": "outfit",
					"name": "Outfit",
					"fontFamily": "'Outfit', 'Helvetica Neue', Arial, sans-serif",
					"fontFace": [
						{
							"fontFamily": "Outfit",
							"fontStyle": "normal",
							"fontWeight": "100 900",
							"fontDisplay": "swap",
							"src": [
								"file:./assets/fonts/outfit/outfit-variable.woff2"
							]
						}
					]
				}
			],
			"fontSizes": [
				{
					"slug": "2xs",
					"size": "0.6875rem",
					"name": "2X-Small"
				},
				{
					"slug": "xs",
					"size": "clamp(0.75rem,0.72rem + 0.15vw,0.875rem)",
					"name": "X-Small"
				},
				{
					"slug": "sm",
					"size": "clamp(0.875rem,0.83rem + 0.22vw,1rem)",
					"name": "Small"
				},
				{
					"slug": "base",
					"size": "clamp(1rem,0.96rem + 0.2vw,1.125rem)",
					"name": "Base"
				},
				{
					"slug": "md",
					"size": "clamp(1.125rem,1.07rem + 0.27vw,1.25rem)",
					"name": "Medium"
				},
				{
					"slug": "lg",
					"size": "clamp(1.25rem,1.15rem + 0.5vw,1.5rem)",
					"name": "Large"
				},
				{
					"slug": "xl",
					"size": "clamp(1.5rem,1.35rem + 0.75vw,2rem)",
					"name": "X-Large"
				},
				{
					"slug": "2xl",
					"size": "clamp(1.75rem,1.5rem + 1.25vw,2.5rem)",
					"name": "2X-Large"
				},
				{
					"slug": "3xl",
					"size": "clamp(2rem,1.6rem + 2vw,3.5rem)",
					"name": "3X-Large"
				},
				{
					"slug": "4xl",
					"size": "clamp(2.5rem,1.9rem + 3vw,5rem)",
					"name": "4X-Large"
				},
				{
					"slug": "display",
					"size": "clamp(3rem,1.8rem + 6vw,7.5rem)",
					"name": "Display"
				}
			],
			"defaultFontSizes": false,
			"lineHeight": true,
			"letterSpacing": true,
			"textTransform": true,
			"textDecoration": true,
			"fluid": true,
			"customFontSize": false
		},
		"spacing": {
			"spacingSizes": [
				{
					"slug": "1",
					"size": "0.25rem",
					"name": "1"
				},
				{
					"slug": "2",
					"size": "0.5rem",
					"name": "2"
				},
				{
					"slug": "3",
					"size": "0.75rem",
					"name": "3"
				},
				{
					"slug": "4",
					"size": "1rem",
					"name": "4"
				},
				{
					"slug": "5",
					"size": "1.5rem",
					"name": "5"
				},
				{
					"slug": "6",
					"size": "2rem",
					"name": "6"
				},
				{
					"slug": "8",
					"size": "2.5rem",
					"name": "8"
				},
				{
					"slug": "10",
					"size": "3rem",
					"name": "10"
				},
				{
					"slug": "12",
					"size": "4rem",
					"name": "12"
				},
				{
					"slug": "16",
					"size": "6rem",
					"name": "16"
				},
				{
					"slug": "20",
					"size": "8rem",
					"name": "20"
				},
				{
					"slug": "24",
					"size": "10rem",
					"name": "24"
				}
			],
			"defaultSpacingSizes": false,
			"padding": true,
			"margin": true,
			"blockGap": true,
			"units": [
				"px",
				"%",
				"em",
				"rem",
				"vw",
				"vh"
			]
		},
		"shadow": {
			"defaultPresets": false,
			"presets": [
				{
					"name": "None",
					"slug": "none",
					"shadow": "none"
				},
				{
					"name": "Card",
					"slug": "card",
					"shadow": "0 2px 8px rgba(28,28,28,0.10)"
				},
				{
					"name": "Card Raised",
					"slug": "card-raised",
					"shadow": "0 6px 24px rgba(28,28,28,0.14)"
				}
			]
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"dimensions": {
			"minHeight": true
		},
		"background": {
			"backgroundImage": true
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--parcel-cream)",
			"text": "var(--wp--preset--color--parcel-carbon)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--outfit)",
			"fontSize": "var(--wp--preset--font-size--base)",
			"lineHeight": "1.65"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--8)"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "800",
					"lineHeight": "1.0",
					"letterSpacing": "-0.03em"
				},
				"color": {
					"text": "var(--wp--preset--color--parcel-carbon)"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "700",
					"lineHeight": "1.1",
					"letterSpacing": "-0.02em"
				},
				"color": {
					"text": "var(--wp--preset--color--parcel-carbon)"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "700",
					"lineHeight": "1.18",
					"letterSpacing": "-0.015em"
				},
				"color": {
					"text": "var(--wp--preset--color--parcel-charcoal)"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "600",
					"lineHeight": "1.25"
				},
				"color": {
					"text": "var(--wp--preset--color--parcel-charcoal)"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--outfit)",
					"fontWeight": "600",
					"letterSpacing": "0.1em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--parcel-slate)"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--outfit)",
					"fontWeight": "700",
					"letterSpacing": "0.14em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--parcel-mist)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--parcel-carbon)"
				},
				"typography": {
					"textDecoration": "underline"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--parcel-orange)"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--parcel-orange)",
					"text": "var(--wp--preset--color--parcel-cream)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "700",
					"letterSpacing": "0.04em"
				},
				"border": {
					"radius": "0"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--parcel-carbon)"
					}
				}
			}
		},
		"blocks": {
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "700",
					"lineHeight": "1.1",
					"textDecoration": "none"
				},
				"color": {
					"text": "var(--wp--preset--color--parcel-carbon)"
				}
			},
			"core/post-excerpt": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--outfit)",
					"lineHeight": "1.6"
				},
				"color": {
					"text": "var(--wp--preset--color--parcel-charcoal)"
				}
			},
			"core/post-date": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--outfit)",
					"fontWeight": "500",
					"letterSpacing": "0.08em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--parcel-mist)"
				}
			},
			"core/post-terms": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--outfit)",
					"fontWeight": "600",
					"letterSpacing": "0.12em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--parcel-orange)"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--syne)",
					"fontWeight": "700",
					"letterSpacing": "-0.01em",
					"textDecoration": "none"
				},
				"color": {
					"text": "var(--wp--preset--color--parcel-carbon)"
				}
			},
			"core/site-tagline": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--outfit)",
					"fontWeight": "400",
					"letterSpacing": "0.08em",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--parcel-mist)"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--outfit)",
					"fontWeight": "500",
					"letterSpacing": "0.02em"
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--wp--preset--color--parcel-orange)",
					"style": "solid",
					"width": "0 0 0 4px"
				},
				"color": {
					"background": "var(--wp--preset--color--parcel-linen)"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|5",
						"bottom": "var:preset|spacing|5",
						"left": "var:preset|spacing|6",
						"right": "var:preset|spacing|6"
					}
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--parcel-rule)"
				},
				"border": {
					"color": "var(--wp--preset--color--parcel-rule)",
					"width": "1px"
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		},
		{
			"name": "post-meta",
			"title": "Post Meta"
		}
	],
	"customTemplates": [
		{
			"name": "page-blank",
			"title": "Blank — no header or footer"
		},
		{
			"name": "page-wide",
			"title": "Wide — full-width content"
		}
	]
}
